input {
    keyboard {
        xkb {
            layout "us"
            options "caps:escape"
        }
        repeat-delay 250
        repeat-rate 50
        numlock
    }
    touchpad {
        natural-scroll
    }
    mouse
}

output "Acer Technologies XV320QU LV 13110DBDC4200" {
    mode "2560x1440@170.071"
}

hotkey-overlay {
    skip-at-startup
}

prefer-no-csd

debug {
    honor-xdg-activation-with-invalid-serial
}

workspace "1"
workspace "2"
workspace "3"

layout {
    gaps 10
    background-color "transparent"
    shadow {
        color "#00000077"
    }
    focus-ring {
        width 3
        inactive-color "#00000000"
        active-color "#89b3fa"
    }
}

overview {
    workspace-shadow {
        off
    }
}

window-rule {
    geometry-corner-radius 10
    clip-to-geometry true
    draw-border-with-background false
    opacity 0.9
    background-effect {
        blur true
        xray true
    }
}

window-rule {
    match app-id=r"(?i)helium"
    match app-id=r"(?i)zed"
    match app-id=r"(?i)electron"
    open-maximized true
}

window-rule {
    match app-id=r"(?i)helium"
    open-on-workspace "1"
}

window-rule {
    match app-id=r"(?i)electron"
    open-on-workspace "3"
}

layer-rule {
    match namespace=r"^noctalia-wallpaper.*"
    place-within-backdrop true
}

binds {
    Mod+Return { spawn "ghostty"; }
    Mod+B      { spawn "helium"; }
    Mod+D      { spawn "equibop"; }
    Mod+Z      { spawn "zeditor"; }

    Mod+P     { spawn "noctalia-shell" "ipc" "call" "sessionMenu" "toggle"; }
    Mod+C     { spawn "noctalia-shell" "ipc" "call" "controlCenter" "toggle"; }
    Mod+Space { spawn "noctalia-shell" "ipc" "call" "launcher" "toggle"; }
    Mod+O     { spawn "noctalia-shell" "ipc" "call" "bar" "toggle"; }
    Mod+Print { spawn "noctalia-shell" "ipc" "call" "plugin:screen-recorder" "saveReplay"; }

    XF86AudioRaiseVolume { spawn "noctalia-shell" "ipc" "call" "volume" "increase"; }
    XF86AudioLowerVolume { spawn "noctalia-shell" "ipc" "call" "volume" "decrease"; }
    XF86AudioMute        { spawn "noctalia-shell" "ipc" "call" "volume" "muteOutput"; }

    Mod+Q       { close-window; }
    Mod+F       { maximize-column; }
    Mod+Shift+F { fullscreen-window; }
    Mod+T       { toggle-window-floating; }
    Mod+Tab     { toggle-overview; }
    Print       { screenshot; }

    Mod+H { focus-column-left; }
    Mod+L { focus-column-right; }
    Mod+J { focus-window-down; }
    Mod+K { focus-window-up; }

    Mod+Shift+H { move-column-left; }
    Mod+Shift+L { move-column-right; }
    Mod+Shift+J { move-window-down; }
    Mod+Shift+K { move-window-up; }

    Mod+Ctrl+H { set-column-width "-5%"; }
    Mod+Ctrl+L { set-column-width "+5%"; }
    Mod+Ctrl+J { set-window-height "-5%"; }
    Mod+Ctrl+K { set-window-height "+5%"; }

    Mod+Alt+J { focus-workspace-down; }
    Mod+Alt+K { focus-workspace-up; }

    Mod+Alt+Shift+J { move-column-to-workspace-down; }
    Mod+Alt+Shift+K { move-column-to-workspace-up; }

    Mod+WheelScrollUp        { focus-workspace-up; }
    Mod+WheelScrollDown      { focus-workspace-down; }
    Mod+Shift+WheelScrollUp  { focus-column-left; }
    Mod+Shift+WheelScrollDown { focus-column-right; }
}

spawn-at-startup "dbus-update-activation-environment" "--systemd" "WAYLAND_DISPLAY" "XDG_CURRENT_DESKTOP=niri"
spawn-at-startup "noctalia-shell"
spawn-at-startup "equibop"
spawn-at-startup "niri" "msg" "action" "focus-workspace" "2"
spawn-at-startup "noctalia-shell ipc call plugin:screen-recorder startReplay"

animations {
    window-open {
        duration-ms 260
        curve "cubic-bezier" 0.22 1.0 0.36 1.0
    }

    window-close {
        duration-ms 180
        curve "cubic-bezier" 0.32 0.0 0.67 0.0
    }

    window-resize {
        spring damping-ratio=1.0 stiffness=720 epsilon=0.0001
    }

    workspace-switch {
        spring damping-ratio=1.0 stiffness=760 epsilon=0.0001
    }

    horizontal-view-movement {
        spring damping-ratio=1.0 stiffness=640 epsilon=0.0001
    }

    window-movement {
        spring damping-ratio=1.0 stiffness=700 epsilon=0.0001
    }

    config-notification-open-close {
        spring damping-ratio=1.0 stiffness=820 epsilon=0.001
    }

    exit-confirmation-open-close {
        spring damping-ratio=1.0 stiffness=560 epsilon=0.01
    }

    screenshot-ui-open {
        duration-ms 220
        curve "cubic-bezier" 0.22 1.0 0.36 1.0
    }

    overview-open-close {
        spring damping-ratio=1.0 stiffness=620 epsilon=0.0001
    }

    recent-windows-close {
        spring damping-ratio=1.0 stiffness=680 epsilon=0.001
    }
}
environment

gestures {
    hot-corners {
        off
    }
}

blur {
    passes 4
}
